apiVersion: apps/v1
kind: Deployment
metadata:
  name: otel-collector-powerscale-cluster{{ cluster_index }}
  namespace: {{ telemetry_namespace }}
  labels:
    app: otel-collector-powerscale
    cluster-index: "{{ cluster_index }}"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: otel-collector-powerscale
      cluster-index: "{{ cluster_index }}"
  template:
    metadata:
      labels:
        app: otel-collector-powerscale
        cluster-index: "{{ cluster_index }}"
    spec:
      containers:
        - name: otel-collector
          image: {{ otel_collector_image }}
          args:
            - --config=/conf/otel-collector-config.yaml
          ports:
            - containerPort: 4317
              name: otlp-grpc
              protocol: TCP
            - containerPort: 4318
              name: otlp-http
              protocol: TCP
            - containerPort: 8889
              name: prometheus
              protocol: TCP
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
          volumeMounts:
            - name: config
              mountPath: /conf
              readOnly: true
            - name: otel-data
              mountPath: /data
      volumes:
        - name: config
          configMap:
            name: otel-collector-powerscale-config-cluster{{ cluster_index }}
        - name: otel-data
          persistentVolumeClaim:
            claimName: otel-collector-powerscale-cluster{{ cluster_index }}-storage
