apiVersion: v1
kind: ConfigMap
metadata:
  name: otel-collector-powerscale-config-cluster{{ cluster_index }}
  namespace: {{ telemetry_namespace }}
data:
  otel-collector-config.yaml: |
    receivers:
      otlp:
        protocols:
          grpc:
            endpoint: 0.0.0.0:4317
          http:
            endpoint: 0.0.0.0:4318
    processors:
      batch:
        timeout: 10s
        send_batch_size: 1024
    exporters:
      prometheus:
        endpoint: 0.0.0.0:8889
        namespace: powerscale
        const_labels:
          source: powerscale
          cluster: "{{ ps_cluster_name }}"
          cluster_endpoint: "{{ ps_cluster_endpoint }}"
    service:
      pipelines:
        metrics:
          receivers: [otlp]
          processors: [batch]
          exporters: [prometheus]
