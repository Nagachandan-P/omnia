# PowerScale Telemetry Verification Script
# Generated by Omnia discovery playbook

NAMESPACE="{{ telemetry_namespace }}"
PASS=0
FAIL=0
WARN=0

echo "=============================================="
echo " PowerScale Telemetry Verification"
echo "=============================================="
echo ""

# 1. Check Kubernetes connectivity
echo "[1/8] Checking Kubernetes connectivity..."
if kubectl cluster-info &>/dev/null; then
    echo "  PASS: Kubernetes cluster is reachable"
    ((PASS++))
else
    echo "  FAIL: Cannot connect to Kubernetes cluster"
    ((FAIL++))
fi

# 2. Check namespace
echo "[2/8] Checking telemetry namespace..."
if kubectl get namespace "$NAMESPACE" &>/dev/null; then
    echo "  PASS: Namespace '$NAMESPACE' exists"
    ((PASS++))
else
    echo "  FAIL: Namespace '$NAMESPACE' does not exist"
    ((FAIL++))
fi

# 3. Check PowerScale CSI secret
echo "[3/8] Checking PowerScale credentials secret..."
if kubectl get secret isilon-creds -n "$NAMESPACE" &>/dev/null; then
    echo "  PASS: Secret 'isilon-creds' exists"
    ((PASS++))
else
    echo "  FAIL: Secret 'isilon-creds' not found in namespace '$NAMESPACE'"
    ((FAIL++))
fi

# 4. Check shared vmagent (also scrapes PowerScale targets)
echo "[4/7] Checking shared vmagent deployment..."
VMAGENT_READY=$(kubectl get deployment vmagent -n "$NAMESPACE" -o jsonpath='{.status.readyReplicas}' 2>/dev/null)
if [ "$VMAGENT_READY" == "1" ]; then
    echo "  PASS: shared vmagent is ready (1/1) - scrapes PowerScale OTEL Collectors"
    ((PASS++))
else
    echo "  FAIL: shared vmagent is not ready (ready: ${VMAGENT_READY:-0})"
    ((FAIL++))
    echo "  DEBUG: kubectl logs -n $NAMESPACE -l app=vmagent --tail=20"
fi

# 5. Check CSM Metrics deployments (per cluster)
echo "[5/7] Checking CSM Metrics PowerScale deployments..."
CSM_DEPLOYMENTS=$(kubectl get deployment -n "$NAMESPACE" -l app=csm-metrics-powerscale -o name 2>/dev/null)
if [ -n "$CSM_DEPLOYMENTS" ]; then
    for dep in $CSM_DEPLOYMENTS; do
        DEP_NAME=$(echo "$dep" | sed 's|deployment.apps/||')
        READY=$(kubectl get "$dep" -n "$NAMESPACE" -o jsonpath='{.status.readyReplicas}' 2>/dev/null)
        EXPECTED=$(kubectl get "$dep" -n "$NAMESPACE" -o jsonpath='{.spec.replicas}' 2>/dev/null)
        if [ "$READY" == "$EXPECTED" ]; then
            echo "  PASS: $DEP_NAME is ready ($READY/$EXPECTED)"
            ((PASS++))
        else
            echo "  FAIL: $DEP_NAME is not ready (${READY:-0}/$EXPECTED)"
            ((FAIL++))
        fi
    done
else
    echo "  FAIL: No CSM Metrics PowerScale deployments found"
    ((FAIL++))
fi

# 6. Check OTEL Collector deployments (per cluster)
echo "[6/7] Checking OTEL Collector PowerScale deployments..."
OTEL_DEPLOYMENTS=$(kubectl get deployment -n "$NAMESPACE" -l app=otel-collector-powerscale -o name 2>/dev/null)
if [ -n "$OTEL_DEPLOYMENTS" ]; then
    for dep in $OTEL_DEPLOYMENTS; do
        DEP_NAME=$(echo "$dep" | sed 's|deployment.apps/||')
        READY=$(kubectl get "$dep" -n "$NAMESPACE" -o jsonpath='{.status.readyReplicas}' 2>/dev/null)
        EXPECTED=$(kubectl get "$dep" -n "$NAMESPACE" -o jsonpath='{.spec.replicas}' 2>/dev/null)
        if [ "$READY" == "$EXPECTED" ]; then
            echo "  PASS: $DEP_NAME is ready ($READY/$EXPECTED)"
            ((PASS++))
        else
            echo "  FAIL: $DEP_NAME is not ready (${READY:-0}/$EXPECTED)"
            ((FAIL++))
        fi
    done
else
    echo "  FAIL: No OTEL Collector PowerScale deployments found"
    ((FAIL++))
fi

# 7. Check PVCs
echo "[7/7] Checking PVCs and Services..."
for PVC_LABEL in "app=otel-collector-powerscale"; do
    PVCS=$(kubectl get pvc -n "$NAMESPACE" -l "$PVC_LABEL" -o name 2>/dev/null)
    if [ -n "$PVCS" ]; then
        for pvc in $PVCS; do
            PVC_NAME=$(echo "$pvc" | sed 's|persistentvolumeclaim/||')
            STATUS=$(kubectl get "$pvc" -n "$NAMESPACE" -o jsonpath='{.status.phase}' 2>/dev/null)
            if [ "$STATUS" == "Bound" ]; then
                echo "  PASS: PVC '$PVC_NAME' is Bound"
                ((PASS++))
            else
                echo "  WARN: PVC '$PVC_NAME' status: $STATUS"
                ((WARN++))
            fi
        done
    fi
done

# Check OTEL Services
OTEL_SERVICES=$(kubectl get service -n "$NAMESPACE" -l app=otel-collector-powerscale -o name 2>/dev/null)
if [ -n "$OTEL_SERVICES" ]; then
    for svc in $OTEL_SERVICES; do
        SVC_NAME=$(echo "$svc" | sed 's|service/||')
        echo "  PASS: Service '$SVC_NAME' exists"
        ((PASS++))
    done
fi

# Summary
echo ""
echo "=============================================="
echo " Verification Summary"
echo "=============================================="
echo "  PASSED: $PASS"
echo "  FAILED: $FAIL"
echo "  WARNINGS: $WARN"
echo ""

if [ $FAIL -eq 0 ]; then
    echo "  STATUS: ALL CHECKS PASSED"
else
    echo "  STATUS: SOME CHECKS FAILED"
    echo ""
    echo "  Debug Commands:"
    echo "    kubectl get pods -n $NAMESPACE -l app=csm-metrics-powerscale"
    echo "    kubectl get pods -n $NAMESPACE -l app=otel-collector-powerscale"
    echo "    kubectl get pods -n $NAMESPACE -l app=vmagent"
    echo "    kubectl logs -n $NAMESPACE -l app=csm-metrics-powerscale --tail=50"
    echo "    kubectl logs -n $NAMESPACE -l app=vmagent --tail=50"
fi

echo ""
echo "=============================================="
exit $FAIL
