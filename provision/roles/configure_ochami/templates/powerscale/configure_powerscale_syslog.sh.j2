# PowerScale Syslog Collection — rsyslog relay + VLAgent
#
# DATA PIPELINE (supports both UDP and TLS modes):
#   UDP mode: PowerScale (UDP:514) → K8s node rsyslog → VLAgent LB (TCP:514) → VictoriaLogs
#   TLS mode: PowerScale (TLS:6514) → VLAgent LB (TLS:6514) → VictoriaLogs
#
# TLS mode is {% if syslog_tls_enabled | default(true) | bool %}enabled{% else %}disabled{% endif %}
#
# What this script does:
#   1. Gets VLAgent LoadBalancer external IP
#   2. Configures rsyslog on the local node (UDP listener, filter by PS IP, forward to VLAgent)
#   3. Opens firewall port 514/udp
#   4. SSHes to all other K8s nodes and repeats steps 2-3
#   5. Prints manual PowerScale configuration instructions (isi audit settings)
#
# NOTE: Omnia does NOT configure PowerScale directly.
#   The user must configure PowerScale to send UDP syslog to any K8s node IP on port 514.

set -euo pipefail

NAMESPACE="{{ telemetry_namespace }}"
K8S_MASTER_IP="{{ kube_vip }}"

# PowerScale syslog source IPs — from powerscale_configurations.powerscale_syslog_source_ips
# These are the IPs from which PowerScale SENDS syslog (often data pool, not mgmt IP).
# Used for rsyslog $fromhost-ip filtering on K8s nodes.
POWERSCALE_IPS=(
{% for ip in powerscale_management_ips %}
    "{{ ip }}"
{% endfor %}
)

echo "=========================================="
echo "PowerScale Syslog Collection Setup"
echo "=========================================="
echo "Pipeline: PowerScale (UDP:514) → rsyslog → VLAgent (TCP:514) → VictoriaLogs"
echo "PowerScale Syslog Source IPs: ${POWERSCALE_IPS[*]}"
echo ""

# ============================================================================
# Phase 1: Get VLAgent LoadBalancer External IP
# ============================================================================
echo "===== Phase 1: Getting VLAgent Service Endpoint ====="

VLAGENT_SERVICE=$(kubectl get svc vlagent-vlagent -n "$NAMESPACE" -o json 2>/dev/null) || {
    echo "ERROR: VLAgent service not found in namespace $NAMESPACE"
    echo "Ensure VLAgent is deployed before running syslog setup."
    exit 0
}

SERVICE_TYPE=$(echo "$VLAGENT_SERVICE" | jq -r '.spec.type')
echo "VLAgent service type: $SERVICE_TYPE"

if [ "$SERVICE_TYPE" == "LoadBalancer" ]; then
    for i in $(seq 1 12); do
        VLAGENT_IP=$(kubectl get svc vlagent-vlagent -n "$NAMESPACE" \
            -o jsonpath='{.status.loadBalancer.ingress[0].ip}' 2>/dev/null)
        if [ -n "$VLAGENT_IP" ] && [ "$VLAGENT_IP" != "null" ]; then
            break
        fi
        echo "  Waiting for LoadBalancer IP assignment... ($i/12)"
        sleep 5
    done
    if [ -z "$VLAGENT_IP" ] || [ "$VLAGENT_IP" == "null" ]; then
        echo "WARNING: LoadBalancer IP not assigned. Using kube_vip: $K8S_MASTER_IP"
        VLAGENT_IP="$K8S_MASTER_IP"
    fi
else
    VLAGENT_IP="$K8S_MASTER_IP"
fi

echo "VLAgent TCP endpoint: ${VLAGENT_IP}:514"
echo ""

# ============================================================================
# Phase 2: Generate rsyslog configuration
# ============================================================================
echo "===== Phase 2: Generating rsyslog Configuration ====="

RSYSLOG_CONF="/etc/rsyslog.d/omnia-powerscale-syslog.conf"

# Build the rsyslog config with filters for each PowerScale management IP
generate_rsyslog_config() {
    cat <<'RSYSLOG_HEADER'
# Omnia PowerScale Syslog Relay Configuration
# Auto-generated by configure_powerscale_syslog.sh
# Pipeline: PowerScale (UDP:514) → rsyslog → VLAgent (TCP:514) → VictoriaLogs
#
# DO NOT EDIT — this file is managed by Omnia.
# Changes will be overwritten on next deployment.

# Load UDP syslog receiver module
module(load="imudp")
input(type="imudp" port="514")

# Template for PowerScale audit logs
template(name="PowerScaleFormat" type="list") {
    property(name="timegenerated" dateFormat="rfc3339")
    constant(value=" ")
    property(name="hostname")
    constant(value=" ")
    property(name="programname")
    constant(value=" ")
    property(name="msg")
    constant(value="\n")
}

RSYSLOG_HEADER

    # Generate a filter block for each PowerScale management IP
    for PS_IP in "${POWERSCALE_IPS[@]}"; do
        cat <<RSYSLOG_FILTER
# PowerScale cluster: ${PS_IP}
if \$fromhost-ip == '${PS_IP}' then {
    # Store local copy for audit trail
    action(type="omfile"
        file="/var/log/powerscale_audit.log"
        template="PowerScaleFormat"
    )

    # Forward to VLAgent LoadBalancer via TCP
    action(type="omfwd"
        target="${VLAGENT_IP}"
        port="514"
        protocol="tcp"
        queue.type="linkedList"
        queue.size="10000"
        queue.filename="fwd_vlagent_${PS_IP//\./_}"
        queue.saveonshutdown="on"
        action.resumeRetryCount="-1"
        action.resumeInterval="10"
    )
    stop
}

RSYSLOG_FILTER
    done
}

RSYSLOG_CONFIG=$(generate_rsyslog_config)
echo "  rsyslog config generated for ${#POWERSCALE_IPS[@]} PowerScale cluster(s)"
echo "  Forward target: ${VLAGENT_IP}:514 (TCP)"

# ============================================================================
# Phase 3: Apply rsyslog configuration on local node
# ============================================================================
echo ""
echo "===== Phase 3: Configuring rsyslog on Local Node ====="

configure_rsyslog_on_node() {
    local NODE_IP="$1"
    local IS_LOCAL="$2"

    if [ "$IS_LOCAL" == "true" ]; then
        echo "  Configuring local node..."

        # Write rsyslog config
        echo "$RSYSLOG_CONFIG" > "$RSYSLOG_CONF"

        # Ensure log file exists with correct permissions
        touch /var/log/powerscale_audit.log
        chmod 640 /var/log/powerscale_audit.log

        # Open firewall port 514/udp (for PowerScale syslog)
        if command -v firewall-cmd &>/dev/null; then
            firewall-cmd --add-port=514/udp --permanent 2>/dev/null || true
            firewall-cmd --add-port=514/tcp --permanent 2>/dev/null || true
            firewall-cmd --reload 2>/dev/null || true
            echo "  Firewall: ports 514/udp and 514/tcp opened"
        fi

        # Restart rsyslog
        systemctl restart rsyslog 2>/dev/null || {
            echo "  WARNING: Failed to restart rsyslog on local node"
            return 1
        }
        echo "  rsyslog restarted successfully on local node"
    else
        echo "  Configuring remote node: ${NODE_IP}..."

        # Copy rsyslog config via SSH
        ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 "$NODE_IP" \
            "cat > $RSYSLOG_CONF" <<< "$RSYSLOG_CONFIG" 2>/dev/null || {
            echo "  WARNING: Failed to write rsyslog config on ${NODE_IP}"
            return 1
        }

        # Ensure log file, open firewall, restart rsyslog
        ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 "$NODE_IP" bash <<'REMOTE_CMD' 2>/dev/null || {
            touch /var/log/powerscale_audit.log
            chmod 640 /var/log/powerscale_audit.log
            if command -v firewall-cmd &>/dev/null; then
                firewall-cmd --add-port=514/udp --permanent 2>/dev/null || true
                firewall-cmd --add-port=514/tcp --permanent 2>/dev/null || true
                firewall-cmd --reload 2>/dev/null || true
            fi
            systemctl restart rsyslog
REMOTE_CMD
            echo "  WARNING: Failed to configure rsyslog on ${NODE_IP}"
            return 1
        }
        echo "  rsyslog configured on ${NODE_IP}"
    fi
    return 0
}

# Configure local node first
configure_rsyslog_on_node "localhost" "true"

# ============================================================================
# Phase 4: Configure rsyslog on all other K8s nodes
# ============================================================================
echo ""
echo "===== Phase 4: Configuring rsyslog on Other K8s Nodes ====="

LOCAL_IP=$(hostname -I | awk '{print $1}')
NODE_IPS=$(kubectl get nodes -o wide --no-headers 2>/dev/null | awk '{print $6}')
NODE_SUCCESS=1
NODE_FAIL=0

for NODE_IP in $NODE_IPS; do
    # Skip the local node
    if [ "$NODE_IP" == "$LOCAL_IP" ] || [ "$NODE_IP" == "$K8S_MASTER_IP" ]; then
        continue
    fi
    if configure_rsyslog_on_node "$NODE_IP" "false"; then
        NODE_SUCCESS=$((NODE_SUCCESS + 1))
    else
        NODE_FAIL=$((NODE_FAIL + 1))
    fi
done

echo ""
echo "rsyslog configured on $NODE_SUCCESS node(s), $NODE_FAIL failure(s)"

# ============================================================================
# Phase 5: Verification
# ============================================================================
echo ""
echo "===== Phase 5: Verification ====="

VLAGENT_PODS=$(kubectl get pods -n "$NAMESPACE" -l app=vlagent --no-headers 2>/dev/null | wc -l)
echo "VLAgent pods running: $VLAGENT_PODS"

echo "VLAgent service ports:"
kubectl get svc vlagent-vlagent -n "$NAMESPACE" \
    -o jsonpath='{range .spec.ports[*]}  {.name}: {.port}/{.protocol}{"\n"}{end}' 2>/dev/null

EXTERNAL_IP=$(kubectl get svc vlagent-vlagent -n "$NAMESPACE" \
    -o jsonpath='{.status.loadBalancer.ingress[0].ip}' 2>/dev/null)
echo "LoadBalancer External IP: ${EXTERNAL_IP:-N/A}"

echo ""
echo "Checking rsyslog status on local node..."
systemctl is-active rsyslog && echo "  rsyslog is active" || echo "  WARNING: rsyslog is not active"
echo "  Config file: $RSYSLOG_CONF"
echo "  Local audit log: /var/log/powerscale_audit.log"

# ============================================================================
# Phase 6: Print Manual PowerScale Configuration Instructions
# ============================================================================
echo ""
echo "=========================================="
echo "NEXT STEPS: Configure PowerScale OneFS"
echo "=========================================="
echo ""
echo "For complete PowerScale syslog configuration details, including"
echo "manual setup steps for both UDP and TLS modes, refer to Omnia documentation."
echo ""

{% if syslog_tls_enabled | default(true) | bool %}
echo "Omnia supports both UDP and TLS syslog modes. Choose based on your"
echo "security requirements:"
echo ""
echo "  UDP Mode:  Simple, no certificates required (rsyslog relay)"
echo "  TLS Mode:  Secure, requires CA certificate copy (direct to VLAgent)"
echo ""
{% else %}
echo "Omnia is configured for UDP mode only (rsyslog relay)."
echo "TLS mode is disabled via syslog_tls_enabled: false."
echo ""
{% endif %}
echo "--- UDP Mode Configuration (rsyslog relay) ---"
echo ""
echo "Omnia has configured rsyslog on all K8s nodes to relay PowerScale"
echo "audit logs to VLAgent. Configure PowerScale to send UDP syslog to"
echo "any K8s node IP on port 514."
echo ""
echo "K8s Node IPs (any of these can receive syslog):"
for NODE_IP in $NODE_IPS; do
    echo "  - ${NODE_IP}:514"
done
echo ""
echo "Steps for each PowerScale cluster:"
echo ""
echo "1. SSH to PowerScale:"
echo "   ssh <admin_user>@<powerscale_mgmt_ip>"
echo ""
echo "2. Enable audit syslog forwarding for desired event types."
echo "   Replace <NODE_IP> with any K8s node IP listed above."
echo ""
echo "   # For protocol events (file access):"
echo "   isi audit settings global modify \\"
echo "     --protocol-syslog-enabled=1 \\"
echo "     --protocol-syslog-servers=<NODE_IP>:514 \\"
echo "     --protocol-syslog-tls-enabled=0"
echo ""
echo "   # For config events (configuration changes):"
echo "   isi audit settings global modify \\"
echo "     --config-syslog-enabled=1 \\"
echo "     --config-syslog-servers=<NODE_IP>:514 \\"
echo "     --config-syslog-tls-enabled=0"
echo ""
echo "   # For system events (all other events):"
echo "   isi audit settings global modify \\"
echo "     --system-syslog-enabled=1 \\"
echo "     --system-syslog-servers=<NODE_IP>:514 \\"
echo "     --system-syslog-tls-enabled=0"
echo ""
echo "3. Verify configuration:"
echo "   isi audit settings global view"
echo ""

{% if syslog_tls_enabled | default(true) | bool %}
echo "--- TLS Mode Configuration (direct to VLAgent) ---"
echo ""
echo "For secure syslog, configure PowerScale to send TLS syslog directly"
echo "to the VLAgent LoadBalancer IP on port 6514."
echo ""
if [ -n "$EXTERNAL_IP" ]; then
    echo "VLAgent LoadBalancer IP: ${EXTERNAL_IP}"
else
    echo "WARNING: LoadBalancer IP not available. Check MetalLB configuration."
fi
echo ""
echo "Steps for each PowerScale cluster:"
echo ""
echo "1. Copy CA certificate from NFS share to PowerScale:"
echo "   scp <oim_shared_path>/omnia/telemetry/syslog-tls-certs/ca.crt \\"
echo "       <admin_user>@<powerscale_mgmt_ip>:/tmp/vlagent-ca.crt"
echo ""
echo "2. SSH to PowerScale:"
echo "   ssh <admin_user>@<powerscale_mgmt_ip>"
echo ""
echo "3. Import CA certificate:"
echo "   isi certificate import /tmp/vlagent-ca.crt --type=ca"
echo ""
echo "4. Enable TLS syslog forwarding for desired event types."
echo "   Replace <VLAGENT_LB_IP> with the LoadBalancer IP listed above."
echo ""
echo "   # For protocol events (file access):"
echo "   isi audit settings global modify \\"
echo "     --protocol-syslog-enabled=1 \\"
echo "     --protocol-syslog-servers=<VLAGENT_LB_IP>:6514 \\"
echo "     --protocol-syslog-tls-enabled=1"
echo ""
echo "   # For config events (configuration changes):"
echo "   isi audit settings global modify \\"
echo "     --config-syslog-enabled=1 \\"
echo "     --config-syslog-servers=<VLAGENT_LB_IP>:6514 \\"
echo "     --config-syslog-tls-enabled=1"
echo ""
echo "   # For system events (all other events):"
echo "   isi audit settings global modify \\"
echo "     --system-syslog-enabled=1 \\"
echo "     --system-syslog-servers=<VLAGENT_LB_IP>:6514 \\"
echo "     --system-syslog-tls-enabled=1"
echo ""
echo "5. Verify configuration:"
echo "   isi audit settings global view"
echo ""
{% endif %}
echo "For detailed instructions, refer to Omnia documentation."
echo ""
echo "=========================================="
echo "PowerScale syslog collection setup completed!"
echo "=========================================="
exit 0
