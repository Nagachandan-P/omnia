# PowerScale Syslog Collection — Direct to VLAgent
#
# DATA PIPELINE:
#   PowerScale (UDP/TCP:514) -> VLAgent (LoadBalancer IP:514) -> VictoriaLogs

set -euo pipefail

NAMESPACE="{{ telemetry_namespace }}"
KUBE_VIP="{{ kube_vip }}"

POWERSCALE_IPS=(
{% for ip in powerscale_management_ips %}
    "{{ ip }}"
{% endfor %}
)

echo "=========================================="
echo "PowerScale Syslog Collection Setup"
echo "=========================================="
echo "Pipeline: PowerScale (UDP/TCP:514) -> VLAgent (LoadBalancer IP:514) -> VictoriaLogs"
{% raw %}
echo "PowerScale Syslog Source IPs: ${POWERSCALE_IPS[*]}"
{% endraw %}
echo ""

# ============================================================================
# Phase 1: Get VLAgent LoadBalancer IP
# ============================================================================
echo "===== Phase 1: Getting VLAgent LoadBalancer IP ====="

VLAGENT_SERVICE=$(kubectl get svc vlagent-vlagent -n "$NAMESPACE" -o json 2>/dev/null) || {
    echo "ERROR: VLAgent service not found in namespace $NAMESPACE"
    exit 0
}

SERVICE_TYPE=$(echo "$VLAGENT_SERVICE" | jq -r '.spec.type')
echo "VLAgent service type: $SERVICE_TYPE"

if [ "$SERVICE_TYPE" == "LoadBalancer" ]; then
    VLAGENT_IP=$(kubectl get svc vlagent-vlagent -n "$NAMESPACE" \
        -o jsonpath='{.status.loadBalancer.ingress[0].ip}')
    VLAGENT_PORT=514
elif [ "$SERVICE_TYPE" == "NodePort" ]; then
    # Fallback to NodePort if LoadBalancer not available
    echo "WARNING: VLAgent service is NodePort, not LoadBalancer. Using kube_vIP."
    VLAGENT_IP="$KUBE_VIP"
    VLAGENT_PORT=$(kubectl get svc vlagent-vlagent -n "$NAMESPACE" \
        -o jsonpath='{.spec.ports[?(@.name=="syslog")].nodePort}')
else
    echo "ERROR: VLAgent service must be LoadBalancer or NodePort for syslog relay"
    exit 0
fi

if [ -z "$VLAGENT_IP" ]; then
    echo "ERROR: Could not determine VLAgent IP. Falling back to kube_vIP: $KUBE_VIP"
    VLAGENT_IP="$KUBE_VIP"
    VLAGENT_PORT=514
fi

echo "VLAgent forwarding target: ${VLAGENT_IP}:${VLAGENT_PORT}"
echo ""

# ============================================================================
# Phase 2: PowerScale Configuration Instructions
# ============================================================================
echo ""
echo "=========================================="
echo "NEXT STEPS: Configure PowerScale OneFS"
echo "=========================================="

echo "Configure PowerScale to send syslog to: ${VLAGENT_IP}:${VLAGENT_PORT}"
echo "VLAgent LoadBalancer IP: ${VLAGENT_IP}"
echo "Syslog Port: ${VLAGENT_PORT} (UDP/TCP)"
echo ""
echo "Steps for each PowerScale cluster:"
echo ""
echo "1. SSH to PowerScale:"
echo "   ssh <admin_user>@<powerscale_mgmt_ip>"
echo ""
echo "2. Enable audit syslog forwarding:"
echo ""
echo "   # For protocol events (file access):"
echo "   isi audit settings global modify \\"
echo "     --protocol-syslog-enabled=1 \\"
echo "     --protocol-syslog-servers=${VLAGENT_IP}:${VLAGENT_PORT} \\"
echo "     --protocol-syslog-tls-enabled=0"
echo ""
echo "   # For config events:"
echo "   isi audit settings global modify \\"
echo "     --config-syslog-enabled=1 \\"
echo "     --config-syslog-servers=${VLAGENT_IP}:${VLAGENT_PORT} \\"
echo "     --config-syslog-tls-enabled=0"
echo ""
echo "   # For system events:"
echo "   isi audit settings global modify \\"
echo "     --system-syslog-enabled=1 \\"
echo "     --system-syslog-servers=${VLAGENT_IP}:${VLAGENT_PORT} \\"
echo "     --system-syslog-tls-enabled=0"
echo ""
echo "3. Verify configuration:"
echo "   isi audit settings global view"
echo ""
echo "=========================================="
echo "PowerScale syslog collection setup completed!"
echo "=========================================="
exit 0
