#!/bin/bash
# HPC benchmark tarball pull script - offline repo only
# Deployed via NFS share for all nodes
# Reads benchmark tool names from benchmark_tools.list
# Copies tarballs from offline repo to /hpc_tools/<tool>/
# Usage: pull_benchmarks.sh

LOGFILE="/var/log/pull_benchmarks.log"
exec > >(tee -a "$LOGFILE") 2>&1

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BENCHMARK_TOOLS_LIST="${SCRIPT_DIR}/benchmark_tools.list"
HPC_TOOLS_DIR="/hpc_tools"
ARCH="$(uname -m)"
OS_VERSION="{{ hostvars['localhost']['cluster_os_version'] }}"
OFFLINE_REPO_BASE="{{ hostvars['localhost']['oim_shared_path'] }}/omnia/offline_repo/cluster"

echo "===== Starting Benchmark Tarball Pull Script (Offline Repo Only) ====="
echo "[INFO] Timestamp: $(date)"
echo "[INFO] Architecture: $ARCH"

# Check prerequisites
if [[ "$ARCH" != "x86_64" && "$ARCH" != "aarch64" ]]; then
    echo "[ERROR] Unsupported architecture: $ARCH"
    exit 1
fi

if [ ! -f "$BENCHMARK_TOOLS_LIST" ]; then
    echo "[ERROR] Benchmark tools list not found: $BENCHMARK_TOOLS_LIST"
    exit 1
fi

if [ ! -d "$HPC_TOOLS_DIR" ]; then
    echo "[ERROR] /hpc_tools is not mounted or does not exist"
    exit 1
fi

echo "[INFO] Reading benchmark tools from: $BENCHMARK_TOOLS_LIST"

TOTAL=0
SUCCESS_COUNT=0
FAILED_COUNT=0
SKIPPED_COUNT=0
FAILED_TOOLS=""

while IFS= read -r tool; do
    [[ -z "$tool" || "$tool" =~ ^[[:space:]]*# ]] && continue
    tool="$(echo "$tool" | xargs)"
    [[ -z "$tool" ]] && continue

    ((TOTAL++))

    echo ""
    echo "===== Processing Tool $TOTAL: $tool ====="

    if [[ "$tool" == "msr-safe" && "$ARCH" != "x86_64" ]]; then
        echo "[WARN] $tool is x86_64 only. Skipping on $ARCH."
        ((SKIPPED_COUNT++))
        continue
    fi

    SOURCE_DIR="${OFFLINE_REPO_BASE}/${ARCH}/rhel/${OS_VERSION}/tarball/${tool}"
    DEST_DIR="${HPC_TOOLS_DIR}/${tool}"

    echo "[INFO] Source: $SOURCE_DIR"
    echo "[INFO] Destination: $DEST_DIR"

    # Skip if source not found in offline repo
    if [ ! -d "$SOURCE_DIR" ]; then
        echo "[WARN] Source not found in offline repo: $SOURCE_DIR. Skipping."
        ((SKIPPED_COUNT++))
        FAILED_TOOLS="${FAILED_TOOLS}\n  - ${tool} (source not found in offline repo)"
        continue
    fi

    # Skip if already staged
    if [ -n "$(ls -A "$DEST_DIR" 2>/dev/null || true)" ]; then
        echo "[WARN] $tool already present at $DEST_DIR. Skipping."
        ((SKIPPED_COUNT++))
        continue
    fi

    mkdir -p "$DEST_DIR"

    cp -r "${SOURCE_DIR}/"* "$DEST_DIR/" 2>&1
    COPY_EXIT_CODE=$?

    if [ $COPY_EXIT_CODE -eq 0 ] && [ -n "$(ls -A "$DEST_DIR")" ]; then
        echo "[SUCCESS] $tool staged at $DEST_DIR"
        ls -lh "$DEST_DIR"
        ((SUCCESS_COUNT++))
    else
        echo "[ERROR] Failed to stage $tool (exit code: $COPY_EXIT_CODE)"
        ((FAILED_COUNT++))
        FAILED_TOOLS="${FAILED_TOOLS}\n  - ${tool}"
    fi

done < "$BENCHMARK_TOOLS_LIST"

echo ""
echo "===== Benchmark Pull Summary ====="
echo "[INFO] Total tools processed: $TOTAL"
echo "[INFO] Successful: $SUCCESS_COUNT"
echo "[INFO] Skipped: $SKIPPED_COUNT"
echo "[INFO] Failed: $FAILED_COUNT"

if [ $FAILED_COUNT -gt 0 ]; then
    echo -e "[ERROR] Failed tools:$FAILED_TOOLS"
    EXIT_CODE=1
else
    EXIT_CODE=0
fi

echo ""
echo "===== Benchmark Pull Completed ====="
exit ${EXIT_CODE:-0}
