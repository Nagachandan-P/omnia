---
apiVersion: v1
kind: ConfigMap
metadata:
  name: mysql-nfs-config
  namespace: {{ telemetry_namespace }}
data:
  nfs.cnf: |
    [mysqld]
    # ---- NFS Compatibility (Safe Settings) ----
    # Use O_DIRECT to bypass OS cache - safe and recommended on NFS
    innodb_flush_method=O_DIRECT
    # Use per-table files for better management and recoverability
    innodb_file_per_table=1
    # Disable async I/O - not reliably supported on NFS
    innodb_use_native_aio=0

    # ---- Crash Safety (DO NOT DISABLE) ----
    # Doublewrite buffer protects against torn pages on crash/reboot - MUST stay enabled
    innodb_doublewrite=1
    # Flush logs on every commit - guarantees no committed transaction is lost
    innodb_flush_log_at_trx_commit=1
    # Sync binary log on every commit (if binlog enabled)
    sync_binlog=1

    # ---- Locking (Safe for NFSv4) ----
    # Keep external locking ENABLED - PowerScale supports NFSv4 locks properly
    # This is a critical safety net against split-brain writes
    # (Removed skip_external_locking=1)

    # ---- Reasonable Timeouts ----
    innodb_lock_wait_timeout=50
---
apiVersion: v1
kind: Service
metadata:
  name: "{{ idrac_telemetry_service_name }}"
  namespace: "{{ telemetry_namespace }}"
  labels:
    app: "{{ idrac_telemetry_service_name }}"
spec:
  clusterIP: None
  ports:
    - name: mysql-port-1
      port: {{ mysqldb_container_port1 }}
    - name: mysql-port-2
      port: {{ mysqldb_container_port2 }}
  selector:
    app: "{{ idrac_telemetry_k8s_name }}"
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ idrac_telemetry_k8s_name }}
  namespace: {{ telemetry_namespace }}
spec:
  podManagementPolicy: Parallel
  serviceName: {{ idrac_telemetry_service_name }}
  replicas: 1
  selector:
    matchLabels:
      app: {{ idrac_telemetry_k8s_name }}
  template:
    metadata:
      labels:
        app: {{ idrac_telemetry_k8s_name }}
    spec:
      volumes:
{% set types = telemetry_config.telemetry_sources.idrac.collection_targets | default([]) %}
{% if 'kafka' in types %}
        # Mount Kafka cluster CA certificate for TLS verification
        - name: kafka-cluster-ca-cert
          secret:
            secretName: kafka-cluster-ca-cert
            items:
              - key: ca.crt
                path: ca.crt
        # Mount kafkapump user certificates for mTLS authentication
        - name: kafkapump-user-certs
          secret:
            secretName: kafkapump
            items:
              - key: user.crt
                path: user.crt
              - key: user.key
                path: user.key
              - key: ca.crt
                path: ca.crt
{% endif %}
        # MySQL configuration for NFS compatibility
        - name: mysql-config
          configMap:
            name: mysql-nfs-config
      hostAliases:
        - ip: "127.0.0.1"
          hostnames:
            - "mysqldb"

      # CHANGED: Increased from 10s to 120s to allow MySQL to flush dirty pages
      # cleanly to PowerScale NFS before being killed
      terminationGracePeriodSeconds: 120

      # CHANGED: Increased from 5s to 600s (10 minutes).
      # This gives the cluster time to be SURE the node is dead before
      # rescheduling. Critical to prevent split-brain on NFS-backed PVs.
      # If you have node fencing, you can lower this. Without fencing,
      # never go below 300s for a stateful workload on shared storage.
      tolerations:
      - effect: NoExecute
        key: node.kubernetes.io/not-ready
        operator: Exists
        tolerationSeconds: 600
      - effect: NoExecute
        key: node.kubernetes.io/unreachable
        operator: Exists
        tolerationSeconds: 600

      initContainers:
        # Wait for PowerScale PV to fully load before starting MySQL
        - name: wait-for-pv-ready
          image: {{ mysql_image }}
          command:
            - /bin/sh
            - -c
            - |
              echo "Waiting for PowerScale PV to be fully accessible..."
              MAX_WAIT=600   # 10 minutes
              WAITED=0
              
              # Test 1: Confirm directory is readable
              while [ ! -d /var/lib/mysql ] && [ $WAITED -lt $MAX_WAIT ]; do
                echo "Waiting for /var/lib/mysql to be accessible... ($WAITED s)"
                sleep 5
                WAITED=$((WAITED + 5))
              done
              
              # Test 2: If this is an existing DB, ensure critical files are present
              if [ -f /var/lib/mysql/ibdata1 ] || [ -f /var/lib/mysql/mysql.ibd ]; then
                echo "Existing database detected - verifying all critical files are loaded..."
                
                # Wait for undo tablespaces to appear (only required for existing DBs)
                while [ $WAITED -lt $MAX_WAIT ]; do
                  UNDO_COUNT=$(ls /var/lib/mysql/undo_* 2>/dev/null | wc -l)
                  if [ "$UNDO_COUNT" -ge 2 ]; then
                    echo "Found $UNDO_COUNT undo tablespaces - PV is ready"
                    break
                  fi
                  echo "Waiting for undo tablespaces to appear... ($WAITED s, found $UNDO_COUNT/2)"
                  sleep 5
                  WAITED=$((WAITED + 5))
                done
                
                # Verify we actually found them
                UNDO_COUNT=$(ls /var/lib/mysql/undo_* 2>/dev/null | wc -l)
                if [ "$UNDO_COUNT" -lt 2 ]; then
                  echo "ERROR: Undo tablespaces still missing after ${MAX_WAIT}s"
                  echo "Directory contents:"
                  ls -la /var/lib/mysql/
                  exit 1
                fi
                
                # Test 3: Verify we can actually read the data dictionary file
                if [ -f /var/lib/mysql/mysql.ibd ]; then
                  if ! dd if=/var/lib/mysql/mysql.ibd of=/dev/null bs=4k count=1 2>/dev/null; then
                    echo "ERROR: mysql.ibd exists but is not readable - PV not fully loaded"
                    exit 1
                  fi
                fi
              else
                echo "Empty data directory - fresh initialization will proceed"
              fi
              
              echo "PV readiness check passed"
              ls -la /var/lib/mysql/
          volumeMounts:
            - name: mysqldb-pvc
              mountPath: /var/lib/mysql/

      containers:
        - name: mysqldb
          image: {{ mysql_image }}
          imagePullPolicy: IfNotPresent
          volumeMounts:
            - name: mysqldb-pvc
              mountPath: /var/lib/mysql/
            - name: mysql-config
              mountPath: /etc/mysql/conf.d/nfs.cnf
              subPath: nfs.cnf

          # CHANGED: Graceful shutdown using socket auth + longer wait
          lifecycle:
            preStop:
              exec:
                command:
                  - /bin/sh
                  - -c
                  - |
                    echo "Initiating graceful MySQL shutdown..."
                    mysqladmin shutdown -uroot -p"${MYSQL_ROOT_PASSWORD}" || true
                    # Wait for mysqld process to fully exit (max 110s, under grace period)
                    for i in $(seq 1 110); do
                      if ! pgrep -x mysqld > /dev/null; then
                        echo "MySQL stopped cleanly"
                        exit 0
                      fi
                      sleep 1
                    done
                    echo "WARNING: MySQL did not stop in time"

          # ADDED: Liveness/Readiness probes to detect hung MySQL
          readinessProbe:
            exec:
              command:
                - /bin/sh
                - -c
                - mysqladmin ping -uroot -p"${MYSQL_ROOT_PASSWORD}"
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          livenessProbe:
            exec:
              command:
                - /bin/sh
                - -c
                - mysqladmin ping -uroot -p"${MYSQL_ROOT_PASSWORD}"
            initialDelaySeconds: 60
            periodSeconds: 30
            timeoutSeconds: 10
            failureThreshold: 5
          # ADDED: Startup probe gives MySQL time for crash recovery on NFS
          # PowerScale PV mount + MySQL crash recovery can take significant time
          startupProbe:
            exec:
              command:
                - /bin/sh
                - -c
                - mysqladmin ping -uroot -p"${MYSQL_ROOT_PASSWORD}"
            periodSeconds: 15
            timeoutSeconds: 10
            failureThreshold: 80   # Allow up to 20 minutes (80 × 15s) for crash recovery

          env:
            - name: MYSQL_DATABASE
              value: {{ mysqldb_name }}
            - name: MYSQL_USER
              valueFrom:
                secretKeyRef:
                  name: {{ mysqldb_secrets_name }}
                  key: mysqldb_user
            - name: MYSQL_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ mysqldb_secrets_name }}
                  key: mysqldb_password
            - name: MYSQL_ROOT_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ mysqldb_secrets_name }}
                  key: mysqldb_root_password
          ports:
            - containerPort: {{ mysqldb_container_port1 }}
            - containerPort: {{ mysqldb_container_port2 }}

        - name: activemq
          image: {{ activemq_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: {{ activemq_http_port_1 }}
            - containerPort: {{ activemq_http_port_2 }}

        - name: idrac-telemetry-receiver
          image: {{ idrac_telemetry_receiver_image }}
          imagePullPolicy: IfNotPresent
          env:
            - name: MESSAGEBUS_HOST
              value: 127.0.0.1
            - name: MESSAGEBUS_PORT
              value: "{{ messagebus_http_port }}"
            - name: CONFIGUI_HTTP_PORT
              value: "{{ configui_http_port }}"
            - name: MYSQL_DATABASE
              value: {{ mysqldb_name }}
            - name: MYSQL_USER
              valueFrom:
                secretKeyRef:
                  name: {{ mysqldb_secrets_name }}
                  key: mysqldb_user
            - name: MYSQL_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ mysqldb_secrets_name }}
                  key: mysqldb_password
            - name: MYSQL_HOST
              value: mysqldb
            - name: MYSQL_HOST_PORT
              value: "{{ mysqldb_container_port1 }}"

{% if 'kafka' in types %}
        - name: kafka-pump
          image: {{ kafkapump_image }}
          imagePullPolicy: IfNotPresent
          volumeMounts:
            # Mount kafkapump user certificates for mTLS (under /extrabin/certs/)
            - mountPath: /extrabin/certs/kafka-certs
              name: kafkapump-user-certs
              readOnly: true
            # Mount cluster CA certificate (under /extrabin/certs/)
            - mountPath: /extrabin/certs/cluster-ca
              name: kafka-cluster-ca-cert
              readOnly: true
          env:
            - name: MESSAGEBUS_HOST
              value: 127.0.0.1
            - name: MESSAGEBUS_PORT
              value: "{{ messagebus_http_port }}"
            - name: KAFKA_BROKER
              value: "kafka-kafka-bootstrap.telemetry.svc.cluster.local:9093"
            - name: KAFKA_TOPIC
              value: "{{ kafka.topics.idrac.name }}"
            # TLS configuration - using iDRAC Telemetry Reference Tools standard env var names
            # Note: kafkapump prepends /extrabin/certs/ to these paths, so use relative paths
            - name: KAFKA_CACERT
              value: "cluster-ca/ca.crt"
            - name: KAFKA_CLIENT_CERT
              value: "kafka-certs/user.crt"
            - name: KAFKA_CLIENT_KEY
              value: "kafka-certs/user.key"
            - name: KAFKA_SKIP_VERIFY
              value: "false"
            - name: KAFKA_PARTITION
              value: "0"
{% endif %}

{% if 'victoria' in types %}
        - name: victoria-pump
          image: {{ victoriapump_image }}
          imagePullPolicy: IfNotPresent
          env:
            - name: MESSAGEBUS_HOST
              value: 127.0.0.1
            - name: MESSAGEBUS_PORT
              value: "{{ messagebus_http_port }}"
            - name: MESSAGEBUS_TYPE
              value: stomp
          ports:
            - containerPort: 2112
              name: victoriapump
{% endif %}

  volumeClaimTemplates:
    - metadata:
        name: mysqldb-pvc
      spec:
        accessModes: ["ReadWriteOnce"]
        resources:
          requests:
            storage: {{ mysqldb_storage }}
